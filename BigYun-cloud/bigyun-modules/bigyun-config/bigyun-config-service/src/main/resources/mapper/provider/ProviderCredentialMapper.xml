<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bigyun.provider.mapper.ProviderCredentialMapper">

    <resultMap type="com.bigyun.provider.domain.ProviderCredential" id="ProviderCredentialResult">
        <id     property="credentialId"       column="credential_id"      />
        <result property="configId"           column="config_id"          />
        <result property="credentialKey"      column="credential_key"     />
        <result property="credentialValue"    column="credential_value"   />
        <result property="isSensitive"        column="is_sensitive"       />
        <result property="createTime"         column="create_time"        />
        <result property="updateTime"         column="update_time"        />
    </resultMap>

    <sql id="selectProviderCredentialVo">
        select credential_id, config_id, credential_key, credential_value, is_sensitive, create_time, update_time
        from sys_provider_credentials
    </sql>

    <select id="selectByConfigId" parameterType="Long" resultMap="ProviderCredentialResult">
        <include refid="selectProviderCredentialVo"/>
        where config_id = #{configId}
        order by credential_key
    </select>

    <select id="selectByConfigIdAndKey" resultMap="ProviderCredentialResult">
        <include refid="selectProviderCredentialVo"/>
        where config_id = #{configId} and credential_key = #{credentialKey}
    </select>

    <delete id="deleteByConfigId" parameterType="Long">
        delete from sys_provider_credentials where config_id = #{configId}
    </delete>

    <delete id="deleteByConfigIdAndKey">
        delete from sys_provider_credentials
        where config_id = #{configId} and credential_key = #{credentialKey}
    </delete>

</mapper>
