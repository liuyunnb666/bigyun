<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bigyun.payment.mapper.PaymentChannelConfigMapper">

    <resultMap id="PaymentChannelConfigResult" type="com.bigyun.payment.domain.PaymentChannelConfig">
        <id property="configId" column="config_id"/>
        <result property="channelCode" column="channel_code"/>
        <result property="channelName" column="channel_name"/>
        <result property="appId" column="app_id"/>
        <result property="appSecret" column="app_secret"/>
        <result property="merchantId" column="merchant_id"/>
        <result property="notifyUrl" column="notify_url"/>
        <result property="returnUrl" column="return_url"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectPaymentChannelConfigVo">
        select config_id, channel_code, channel_name, app_id, app_secret, merchant_id, notify_url, return_url,
               status, create_by, create_time, update_by, update_time, remark
        from payment_channel_config
    </sql>

    <select id="selectPaymentChannelConfigList" parameterType="com.bigyun.payment.domain.PaymentChannelConfig" resultMap="PaymentChannelConfigResult">
        <include refid="selectPaymentChannelConfigVo"/>
        <where>
            <if test="channelCode != null and channelCode != ''">
                and channel_code like concat('%', #{channelCode}, '%')
            </if>
            <if test="channelName != null and channelName != ''">
                and channel_name like concat('%', #{channelName}, '%')
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by config_id desc
    </select>

    <select id="selectPaymentChannelConfigById" parameterType="Long" resultMap="PaymentChannelConfigResult">
        <include refid="selectPaymentChannelConfigVo"/>
        where config_id = #{configId}
    </select>

    <select id="selectPaymentChannelConfigByCode" parameterType="String" resultMap="PaymentChannelConfigResult">
        <include refid="selectPaymentChannelConfigVo"/>
        where channel_code = #{channelCode}
        limit 1
    </select>

    <insert id="insertPaymentChannelConfig" parameterType="com.bigyun.payment.domain.PaymentChannelConfig" useGeneratedKeys="true" keyProperty="configId">
        insert into payment_channel_config (
            channel_code, channel_name, app_id, app_secret, merchant_id, notify_url, return_url, status, create_by, create_time, remark
        ) values (
            #{channelCode}, #{channelName}, #{appId}, #{appSecret}, #{merchantId}, #{notifyUrl}, #{returnUrl}, #{status}, #{createBy}, sysdate(), #{remark}
        )
    </insert>

    <update id="updatePaymentChannelConfig" parameterType="com.bigyun.payment.domain.PaymentChannelConfig">
        update payment_channel_config
        <set>
            <if test="channelCode != null and channelCode != ''">channel_code = #{channelCode},</if>
            <if test="channelName != null and channelName != ''">channel_name = #{channelName},</if>
            <if test="appId != null">app_id = #{appId},</if>
            <if test="appSecret != null">app_secret = #{appSecret},</if>
            <if test="merchantId != null">merchant_id = #{merchantId},</if>
            <if test="notifyUrl != null">notify_url = #{notifyUrl},</if>
            <if test="returnUrl != null">return_url = #{returnUrl},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where config_id = #{configId}
    </update>

    <delete id="deletePaymentChannelConfigById" parameterType="Long">
        delete from payment_channel_config where config_id = #{configId}
    </delete>

    <delete id="deletePaymentChannelConfigByIds">
        delete from payment_channel_config where config_id in
        <foreach collection="array" item="configId" open="(" separator="," close=")">
            #{configId}
        </foreach>
    </delete>
</mapper>
